{
  "name": "ink-presentation",
  "version": "0.2.0",
  "description": "Present your Markdown notes as beautiful Reveal.js slideshows inside Inkdrop",
  "keywords": [
    "inkdrop",
    "presentation",
    "reveal.js",
    "slides"
  ],
  "license": "MIT",
  "repository": "https://github.com/crafts69guy/ink-presentation",
  "files": [
    "lib/index.js",
    "keymaps",
    "menus",
    "styles",
    "docs"
  ],
  "main": "./lib/index.js",
  "scripts": {
    "gen:css": "node scripts/gen-css.mjs",
    "dev": "npm run gen:css && tsdown --watch",
    "build": "npm run gen:css && tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test",
    "fmt": "oxfmt",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "katex": "^0.17.0",
    "mermaid": "^11.16.0"
  },
  "devDependencies": {
    "@inkdropapp/types": "^0.0.9",
    "@types/event-kit": "^2.4.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/reveal.js": "^5.2.2",
    "dompurify": "^3.4.11",
    "event-kit": "^2.5.3",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.0",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.0.0",
    "reveal.js": "^5.2.1",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "inkdrop": "^6.0.0"
  }
}
